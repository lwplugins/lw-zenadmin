includes:
	- phpstan-baseline.neon
	- vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
	level: 5

	# The plugin supports PHP 8.0 upwards, so analyse against the lowest
	# supported version — anything newer would let 8.1+ syntax slip through.
	phpVersion:
		min: 80000
		max: 80599

	paths:
		- lw-zenadmin.php
		- includes/

	excludePaths:
		- tests/
		- vendor/

	# Declare the plugin's runtime-defined constants for static analysis.
	bootstrapFiles:
		- phpstan-bootstrap.php

	# Third-party APIs the plugin integrates with. WordPress core stubs come
	# from the szepeviktor/phpstan-wordpress extension above.
	scanFiles:
		- vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
