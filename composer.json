{
    "name": "lwplugins/lw-zenadmin",
    "description": "Clean up your WordPress admin — collect notices and manage dashboard widgets.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "LW Plugins",
            "homepage": "https://lwplugins.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer/installers": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.0",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/wp-cli-stubs": "^2.12",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "LightweightPlugins\\ZenAdmin\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LightweightPlugins\\ZenAdmin\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "analyse": "phpstan analyse --memory-limit=2G",
        "test": "phpunit"
    }
}
